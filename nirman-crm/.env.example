# Supabase cloud project
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Project ref (used by `supabase link`)
SUPABASE_PROJECT_REF=

# Local dev (auto-set by `supabase start`)
SUPABASE_LOCAL_URL=http://localhost:54321
SUPABASE_LOCAL_ANON_KEY=

# Story 1.2 — bootstrap-admin Edge Function (one-time setup)
# Generate with: openssl rand -base64 32
# Set as Edge Function secret in Supabase Dashboard → Settings → Edge Functions → Secrets
BOOTSTRAP_SECRET=replace_with_secure_random_string
