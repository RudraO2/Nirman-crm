{
  "name": "nirman-crm",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/admin",
    "apps/marketing",
    "apps/ops",
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "supabase:start": "supabase --workdir supabase start",
    "supabase:stop": "supabase --workdir supabase stop",
    "supabase:test": "supabase --workdir supabase test db",
    "supabase:gen-types": "supabase gen types typescript --linked > packages/shared-types/index.ts"
  }
}
